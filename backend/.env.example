# ===== COPY THIS FILE TO .env AND FILL IN VALUES =====
# .env is gitignored. Never commit real secrets.

# ----- App -----
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ----- Database -----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rareoff
DB_USER=rareoff
DB_PASSWORD=rareoff_dev_password

# ----- pgAdmin (dev only) -----
PGADMIN_EMAIL=admin@rareoff.local
PGADMIN_PASSWORD=admin

# ----- CORS (frontend origins, comma-separated) -----
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ----- JWT (used from Phase 1) -----
JWT_SECRET=change_me_min_32_chars_long_random_string_here
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=14

# ----- Razorpay (test-mode keys from dashboard.razorpay.com) -----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=any_string_set_in_razorpay_webhook
RAZORPAY_CURRENCY=INR
